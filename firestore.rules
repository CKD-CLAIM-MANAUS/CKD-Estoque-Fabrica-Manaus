rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    // Só é usuário legítimo quem tem PERFIL (doc em users/{uid}), criado pelo admin.
    // Quem se cadastra sozinho (signUp público) não tem perfil → não lê nada.
    function hasProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Perfis de usuário (email + papel)
    // Cada um lê só o próprio doc; admin lê todos.
    match /users/{uid} {
      allow read:  if isSignedIn() && (request.auth.uid == uid || role() == 'admin');
      allow write: if isSignedIn() && role() == 'admin';
    }

    // Mapa de vagas — documento único estoque/vagas
    match /estoque/{docId} {
      allow read:  if hasProfile();
      allow write: if hasProfile() && role() in ['admin', 'validador', 'operador'];
    }

    // Histórico de movimentações
    match /historico/{docId} {
      allow read:   if hasProfile();
      allow create: if hasProfile() && role() in ['admin', 'validador', 'operador'];
      allow update, delete: if hasProfile() && role() == 'admin';
    }

    // Pedidos — sincronizados do Excel/SharePoint via Power Automate.
    // O Power Automate grava com service account (ignora estas regras).
    // No app: só quem tem perfil lê; admin/validador podem escrever (cadastro manual).
    match /pedidos/{docId} {
      allow read:  if hasProfile();
      allow write: if hasProfile() && role() in ['admin', 'validador'];
    }
  }
}
